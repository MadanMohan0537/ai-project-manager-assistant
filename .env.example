# ─────────────────────────────────────────────────────────────────────────────
# AI Project Manager Assistant — Environment Variables
# Copy this file to .env and fill in your credentials.
# The .env file is git-ignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A: Standard OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o-mini   # or gpt-4o, gpt-3.5-turbo

# ── Option B: Azure OpenAI (takes priority if set) ───────────────────────────
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01
